{
  "designSystem": {
    "name": "MOSC Design System",
    "version": "1.0.0",
    "framework": "Next.js + Tailwind CSS",
    "language": "TypeScript",

    "colors": {
      "burgundy": {
        "DEFAULT": "#C0284A",
        "dark": "#8B1030",
        "light": "#E8406A",
        "muted": "#E8899A"
      },
      "parchment": {
        "DEFAULT": "#F5EDD8",
        "deep": "#EDE0C4",
        "mid": "#F0E6CC",
        "light": "#FDFAF3"
      },
      "warmBrown": {
        "DEFAULT": "#7A1E35",
        "dark": "#3D0D0D"
      },
      "text": {
        "primary": "#3D0D0D",
        "secondary": "#7A1E35",
        "muted": "#9A6A6A",
        "inverse": "#FFFFFF"
      },
      "ui": {
        "border": "#C0284A33",
        "borderStrong": "#C0284A",
        "divider": "#EDE0C4",
        "overlay": "rgba(61,13,13,0.6)"
      }
    },

    "typography": {
      "fontFamily": {
        "primary": "DM Sans, sans-serif",
        "fallback": "system-ui, sans-serif"
      },
      "scale": {
        "xs":   { "size": "10px", "lineHeight": "1.4" },
        "sm":   { "size": "11px", "lineHeight": "1.4" },
        "base": { "size": "14px", "lineHeight": "1.6" },
        "md":   { "size": "16px", "lineHeight": "1.6" },
        "lg":   { "size": "20px", "lineHeight": "1.4" },
        "xl":   { "size": "24px", "lineHeight": "1.3" },
        "2xl":  { "size": "30px", "lineHeight": "1.2" },
        "3xl":  { "size": "36px", "lineHeight": "1.1" }
      },
      "weight": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      }
    },

    "spacing": {
      "pagePaddingX": {
        "mobile": "16px",
        "tablet": "24px",
        "desktop": "64px"
      },
      "sectionPaddingY": {
        "sm": "32px",
        "md": "48px",
        "lg": "64px"
      },
      "cardPadding": "24px",
      "gap": {
        "xs": "4px",
        "sm": "8px",
        "md": "16px",
        "lg": "24px",
        "xl": "32px",
        "2xl": "48px"
      }
    },

    "borderRadius": {
      "none": "0px",
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "pill": "9999px",
      "card": "12px"
    },

    "shadows": {
      "sm":   "0 1px 3px rgba(192,40,74,0.08)",
      "md":   "0 4px 12px rgba(192,40,74,0.12)",
      "lg":   "0 8px 24px rgba(192,40,74,0.18)",
      "card": "0 2px 8px rgba(61,13,13,0.08)",
      "cardHover": "0 8px 24px rgba(192,40,74,0.16)"
    },

    "animations": {
      "transitions": {
        "default":  "all 0.2s ease",
        "medium":   "all 0.3s ease",
        "slow":     "all 0.5s ease",
        "scroll":   "all 0.7s ease-out"
      },
      "scrollReveal": {
        "initial":  { "opacity": 0, "transform": "translateY(40px)" },
        "visible":  { "opacity": 1, "transform": "translateY(0)" },
        "duration": "700ms",
        "easing":   "ease-out"
      },
      "parallax": {
        "hero": "30% scroll speed",
        "sections": "15% scroll speed"
      },
      "hover": {
        "navLink":    "slide-fill underline in burgundy",
        "button":     "scale(1.03) + shadow elevation",
        "card":       "translateY(-4px) + shadow elevation",
        "iconBar":    "translateY(-3px) + burgundy fill",
        "mapRegion":  "glow pulse + pin marker"
      }
    },

    "components": {
      "header": {
        "logoBar": {
          "background": "#FDFAF3",
          "logoSize": "80px",
          "titleColor": "#8B1030",
          "titleSize": "xl"
        },
        "navBar": {
          "background": "#8B1030",
          "textColor": "#FFFFFF",
          "fontSize": "11px",
          "alignment": "right",
          "paddingX": "64px"
        },
        "quickLinksBar": {
          "background": "#C0284A",
          "textColor": "#FFFFFF",
          "fontSize": "10px",
          "alignment": "right",
          "paddingX": "64px"
        }
      },
      "hero": {
        "height": { "mobile": "300px", "desktop": "400px" },
        "overlay": "none",
        "parallaxSpeed": "0.3"
      },
      "ctaIconBar": {
        "background": "#FDFAF3",
        "borderTop": "2px solid #C0284A33",
        "iconColor": "#C0284A",
        "iconSize": "28px",
        "labelSize": "11px",
        "hoverEffect": "lift + burgundy fill"
      },
      "card": {
        "background": "#FDFAF3",
        "border": "1px solid #C0284A33",
        "borderRadius": "12px",
        "padding": "24px",
        "hoverBorder": "#C0284A",
        "hoverShadow": "0 8px 24px rgba(192,40,74,0.16)"
      },
      "button": {
        "primary": {
          "background": "#C0284A",
          "text": "#FFFFFF",
          "borderRadius": "9999px",
          "padding": "10px 24px",
          "hoverBackground": "#8B1030"
        },
        "outline": {
          "background": "transparent",
          "border": "2px solid #C0284A",
          "text": "#C0284A",
          "borderRadius": "9999px",
          "padding": "10px 24px",
          "hoverBackground": "#C0284A",
          "hoverText": "#FFFFFF"
        }
      },
      "section": {
        "default": { "background": "#F5EDD8" },
        "alternate": { "background": "#FDFAF3" },
        "dark": { "background": "#3D0D0D", "text": "#FDFAF3" }
      },
      "map": {
        "ocean": "#A8D5E8",
        "land": "#E8F0DC",
        "borders": "#C8D8B8",
        "regionHighlight": "#E8406A",
        "glowColor": "rgba(232,64,106,0.5)",
        "pinColor": "#C0284A"
      },
      "footer": {
        "background": "#3D0D0D",
        "textColor": "#F5EDD8",
        "accentColor": "#E8406A",
        "borderColor": "#C0284A33"
      }
    },

    "tailwindConfig": {
      "extend": {
        "colors": {
          "burgundy": {
            "DEFAULT": "#C0284A",
            "dark": "#8B1030",
            "light": "#E8406A",
            "muted": "#E8899A"
          },
          "parchment": {
            "DEFAULT": "#F5EDD8",
            "deep": "#EDE0C4",
            "mid": "#F0E6CC",
            "light": "#FDFAF3"
          },
          "warmBrown": {
            "DEFAULT": "#7A1E35",
            "dark": "#3D0D0D"
          }
        },
        "fontFamily": {
          "sans": ["DM Sans", "system-ui", "sans-serif"]
        },
        "boxShadow": {
          "card": "0 2px 8px rgba(61,13,13,0.08)",
          "card-hover": "0 8px 24px rgba(192,40,74,0.16)"
        }
      }
    }
  }
}
