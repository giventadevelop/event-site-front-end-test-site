{
  "designSystem": {
    "name": "Syro-Malabar Creator Analytics Design System",
    "version": "2.0.0",
    "description": "Comprehensive design system extracted from the Creator Analytics Dashboard implementation. Contains exact styling specifications for all components, layouts, and interactions to enable consistent AI-assisted feature development.",
    "basedOn": "Syro-Malabar Church Design System v1.0.0",
    "applicationType": "Creator Analytics Platform Dashboard",
    
    "designPrinciples": {
      "overview": "A modern analytics dashboard design that applies dignified, professional styling from the Syro-Malabar design system. Emphasizes clear data visualization, intuitive navigation, and consistent component patterns.",
      "corePrinciples": [
        "Visual hierarchy through typography and spacing",
        "Data-driven content presentation with clear metrics",
        "Consistent component styling across all features",
        "Elegant use of gradients and shadows for depth",
        "Geometric accents and decorative elements",
        "Responsive-first approach with mobile optimization",
        "Accessibility and readability for all users",
        "Smooth transitions and subtle animations",
        "Clear color coding for positive/negative metrics",
        "Card-based layout for organized information display"
      ],
      "designStyle": "Professional analytics dashboard with modern web aesthetics, featuring layered card compositions, gradient accents, and clear data hierarchy. Maintains dignity and clarity while presenting complex analytics data."
    },
    
    "globalStyles": {
      "reset": {
        "margin": "0",
        "padding": "0",
        "boxSizing": "border-box"
      },
      "body": {
        "fontFamily": "'Poppins', Arial, Helvetica, sans-serif",
        "backgroundColor": "#f5f6f7",
        "color": "#0b2848",
        "overflowX": "hidden"
      },
      "universalSelector": "*",
      "resetProperties": ["margin", "padding", "boxSizing"]
    },
    
    "colorPalette": {
      "primary": {
        "red": {
          "main": "#dc3545",
          "description": "Primary brand color - used for CTAs, accents, and highlights",
          "darker": "#be1929",
          "hover": "#990b3f",
          "light": "#dc354533",
          "usage": ["Primary buttons", "Section title accents", "Hover states", "Important text highlights", "Negative metrics"]
        },
        "blue": {
          "main": "#0b2848",
          "description": "Primary dark blue - main text and headers",
          "secondary": "#011e94",
          "light": "#798daf",
          "dark": "#16253c",
          "usage": ["Main headings", "Navigation", "Body text", "Table headers", "Icon colors"]
        }
      },
      "secondary": {
        "orange": {
          "main": "#ff7903",
          "description": "Accent orange - used for highlights",
          "usage": ["Chart gradients", "Badge warnings"]
        },
        "purple": {
          "main": "#6e1b48",
          "description": "Deep purple - special sections",
          "usage": ["Special section backgrounds"]
        },
        "maroon": {
          "main": "#77121b",
          "description": "Maroon accent - quick actions title",
          "usage": ["Quick actions section titles"]
        }
      },
      "neutrals": {
        "white": "#ffffff",
        "lightGray": "#eaebef",
        "backgroundGray": "#f5f6f7",
        "textGray": "#818181",
        "mediumGray": "#7b869a",
        "darkGray": "#506276",
        "tableBorder": "#eaebef"
      },
      "semantic": {
        "success": {
          "main": "#25d366",
          "background": "#25d36633",
          "usage": ["Positive metrics", "Success badges", "Active status indicators"]
        },
        "warning": {
          "main": "#ff7903",
          "background": "#ffc81533",
          "usage": ["Warning badges", "Draft status"]
        },
        "error": {
          "main": "#dc3545",
          "usage": ["Error states", "Negative metrics"]
        }
      },
      "gradients": {
        "chartPlaceholder": "linear-gradient(-90deg, #dc354662, #ff790348)",
        "statIcon": "linear-gradient(#011e94, #011e94d4, #011e94b3, #011e9433)",
        "userAvatar": "linear-gradient(#011e94, #011e94d4)"
      }
    },
    
    "typography": {
      "fontFamilies": {
        "primary": {
          "name": "Poppins",
          "weights": [100, 200, 300, 400, 500, 600, 700, 800],
          "usage": "General body text, UI elements, navigation, labels",
          "fallback": "Arial, Helvetica, sans-serif"
        },
        "display": {
          "name": "Playfair Display",
          "weights": [400, 600, 700, 800],
          "usage": "Logo text, main titles",
          "fallback": "serif"
        }
      },
      "scale": {
        "logo": {
          "fontFamily": "'Playfair Display', serif",
          "fontSize": "1.5rem",
          "fontWeight": 700,
          "color": "#0b2848",
          "impColor": "#dc3545"
        },
        "h1": {
          "fontSize": "2.8rem",
          "fontWeight": 700,
          "color": "#0b2848",
          "marginBottom": "10px",
          "usage": "Main page titles"
        },
        "h2": {
          "fontSize": "2.2rem",
          "fontWeight": 700,
          "color": "#0b2848",
          "usage": "Stat card values"
        },
        "h3": {
          "fontSize": "1.8rem",
          "fontWeight": 600,
          "color": "#0b2848",
          "usage": "Chart titles, table titles"
        },
        "h4": {
          "fontSize": "1.5rem",
          "fontWeight": 600,
          "color": "#77121b",
          "usage": "Quick actions title"
        },
        "h6": {
          "fontSize": "18px",
          "fontWeight": 600,
          "color": "#0b2848",
          "usage": "Action card titles"
        },
        "body": {
          "fontSize": "20px",
          "fontWeight": 400,
          "color": "#506276",
          "marginBottom": "40px",
          "usage": "Main description text"
        },
        "label": {
          "fontSize": "16px",
          "fontWeight": 300,
          "color": "#7b869a",
          "usage": "Stat card labels"
        },
        "small": {
          "fontSize": "14px",
          "fontWeight": 500,
          "usage": "Change indicators, badges, chart options"
        },
        "sectionTitle": {
          "fontSize": "24px",
          "fontWeight": 300,
          "color": "#798daf",
          "letterSpacing": "5px",
          "writingMode": "vertical-lr",
          "transform": "rotate(180deg)",
          "position": "absolute",
          "left": "-50px",
          "usage": "Vertical section labels"
        }
      },
      "special": {
        "impColor": {
          "color": "#dc3545 !important",
          "usage": "Highlighted text within headings (use .imp-color class)"
        }
      }
    },
    
    "spacing": {
      "scale": {
        "xs": "5px",
        "sm": "10px",
        "md": "15px",
        "lg": "20px",
        "xl": "30px",
        "xxl": "40px",
        "xxxl": "60px"
      },
      "containers": {
        "maxWidth": "1200px",
        "padding": "0 15px",
        "margin": "0 auto"
      },
      "sections": {
        "containerPadding": "60px 15px",
        "sectionMargin": "60px 0",
        "sectionTitleBottom": "40px",
        "mobileContainerPadding": "40px 15px"
      },
      "components": {
        "cardPadding": "40px",
        "cardMarginBottom": "60px",
        "gridGap": "30px",
        "mobileGridGap": "20px",
        "quickActionsPadding": "30px",
        "quickActionsMarginTop": "60px"
      },
      "elements": {
        "tablePadding": "15px",
        "buttonPadding": "10px 20px",
        "actionCardPadding": "20px",
        "actionCardGap": "20px"
      }
    },
    
    "layout": {
      "container": {
        "maxWidth": "1200px",
        "padding": "0 15px",
        "margin": "0 auto",
        "display": "flex/flexbox",
        "usage": "All main content containers"
      },
      "gridSystem": {
        "statsGrid": "repeat(auto-fit, minmax(250px, 1fr))",
        "actionsGrid": "repeat(auto-fit, minmax(200px, 1fr))",
        "gap": "30px",
        "mobileGap": "20px",
        "mobileColumns": "1fr"
      },
      "sections": {
        "defaultPadding": "60px 0",
        "sectionTitlePadding": "80px left padding on desktop",
        "mobileSectionTitlePadding": "15px left padding"
      }
    },
    
    "components": {
      "header": {
        "className": "dashboard-header",
        "properties": {
          "background": "#ffffff",
          "padding": "0.5rem 0",
          "boxShadow": "#0b28487d 0px 10px 25px -10px",
          "position": "sticky",
          "top": 0,
          "zIndex": 999
        },
        "container": {
          "className": "header-container",
          "maxWidth": "1200px",
          "margin": "0 auto",
          "padding": "0 15px",
          "display": "flex",
          "justifyContent": "space-between",
          "alignItems": "center"
        },
        "logo": {
          "fontFamily": "'Playfair Display', serif",
          "fontSize": "1.5rem",
          "fontWeight": 700,
          "color": "#0b2848"
        },
        "navigation": {
          "links": {
            "display": "flex",
            "gap": "30px",
            "listStyle": "none",
            "color": "#0b2848",
            "fontWeight": 500,
            "transition": "0.3s",
            "hover": {
              "color": "#dc3545"
            }
          }
        },
        "userSection": {
          "display": "flex",
          "alignItems": "center",
          "gap": "20px"
        },
        "userAvatar": {
          "width": "40px",
          "height": "40px",
          "borderRadius": "50%",
          "background": "linear-gradient(#011e94, #011e94d4)",
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "center",
          "color": "#fff",
          "fontWeight": 600
        }
      },
      
      "sectionTitle": {
        "className": "section-title",
        "properties": {
          "position": "relative",
          "marginBottom": "40px"
        },
        "h6": {
          "writingMode": "vertical-lr",
          "transform": "rotate(180deg)",
          "letterSpacing": "5px",
          "fontSize": "24px",
          "fontWeight": 300,
          "color": "#798daf",
          "position": "absolute",
          "left": "-50px"
        },
        "accentBar": {
          "pseudoElement": "::after",
          "content": "\"\"",
          "width": "7px",
          "height": "120%",
          "backgroundColor": "#dc3545",
          "position": "absolute",
          "left": "-30px",
          "top": 0
        },
        "mobile": {
          "h6": {
            "writingMode": "horizontal-tb",
            "transform": "none",
            "position": "relative",
            "left": 0,
            "fontSize": "15px",
            "marginBottom": "10px"
          },
          "accentBar": {
            "width": "4px",
            "height": "100%",
            "left": "-15px"
          }
        }
      },
      
      "mainTitle": {
        "className": "main-title",
        "h1": {
          "fontSize": "2.8rem",
          "fontWeight": 700,
          "color": "#0b2848",
          "marginBottom": "10px",
          "mobile": "calc(1.5rem + 1vw)"
        },
        "p": {
          "fontSize": "20px",
          "color": "#506276",
          "marginBottom": "40px"
        }
      },
      
      "statCard": {
        "className": "stat-card",
        "properties": {
          "background": "#ffffff",
          "padding": "40px",
          "borderRadius": "5px",
          "boxShadow": "rgba(50, 50, 93, 0.25) 0px 6px 12px -2px, rgba(0, 0, 0, 0.3) 0px 3px 7px -3px",
          "transition": "0.5s",
          "position": "relative"
        },
        "hover": {
          "boxShadow": "rgba(0, 0, 0, 0.35) 0px 5px 15px"
        },
        "header": {
          "className": "stat-card-header",
          "display": "flex",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginBottom": "20px"
        },
        "icon": {
          "className": "stat-card-icon",
          "width": "65px",
          "height": "65px",
          "background": "linear-gradient(#011e94, #011e94d4, #011e94b3, #011e9433)",
          "borderRadius": "5px",
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "center",
          "color": "#fff",
          "fontSize": "26px"
        },
        "value": {
          "className": "stat-card-value",
          "fontSize": "2.2rem",
          "fontWeight": 700,
          "color": "#0b2848",
          "marginBottom": "5px"
        },
        "label": {
          "className": "stat-card-label",
          "fontSize": "16px",
          "color": "#7b869a",
          "fontWeight": 300
        },
        "change": {
          "className": "stat-card-change",
          "fontSize": "14px",
          "fontWeight": 500,
          "marginTop": "10px",
          "variants": {
            "positive": {
              "color": "#25d366",
              "className": "positive"
            },
            "negative": {
              "color": "#dc3545",
              "className": "negative"
            }
          }
        }
      },
      
      "statsGrid": {
        "className": "stats-grid",
        "display": "grid",
        "gridTemplateColumns": "repeat(auto-fit, minmax(250px, 1fr))",
        "gap": "30px",
        "marginBottom": "60px",
        "mobile": {
          "gridTemplateColumns": "1fr",
          "gap": "20px"
        }
      },
      
      "chartSection": {
        "className": "chart-section",
        "properties": {
          "background": "#ffffff",
          "padding": "40px",
          "borderRadius": "5px",
          "boxShadow": "rgba(50, 50, 93, 0.25) 0px 6px 12px -2px, rgba(0, 0, 0, 0.3) 0px 3px 7px -3px",
          "marginBottom": "60px"
        },
        "header": {
          "className": "chart-header",
          "display": "flex",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginBottom": "30px"
        },
        "title": {
          "className": "chart-title",
          "fontSize": "1.8rem",
          "fontWeight": 600,
          "color": "#0b2848"
        },
        "options": {
          "className": "chart-options",
          "display": "flex",
          "gap": "10px"
        },
        "option": {
          "className": "chart-option",
          "padding": "5px 10px",
          "border": "2px solid #315984",
          "background": "transparent",
          "color": "#0b2848",
          "borderRadius": 0,
          "fontWeight": 500,
          "fontSize": "14px",
          "cursor": "pointer",
          "transition": "1s",
          "active": {
            "background": "#315984",
            "color": "#fff",
            "className": "active"
          },
          "hover": {
            "background": "#315984",
            "color": "#fff"
          }
        },
        "placeholder": {
          "className": "chart-placeholder",
          "height": "400px",
          "background": "linear-gradient(-90deg, #dc354662, #ff790348)",
          "borderRadius": "5px",
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "center",
          "color": "#0b2848",
          "fontSize": "18px",
          "fontWeight": 300,
          "mobile": {
            "height": "250px"
          }
        }
      },
      
      "dataSection": {
        "className": "data-section",
        "properties": {
          "position": "relative",
          "paddingLeft": "80px"
        },
        "mobile": {
          "paddingLeft": "15px"
        }
      },
      
      "dataTableCard": {
        "className": "data-table-card",
        "properties": {
          "background": "#ffffff",
          "padding": "40px",
          "borderRadius": "5px",
          "boxShadow": "rgba(50, 50, 93, 0.25) 0px 6px 12px -2px, rgba(0, 0, 0, 0.3) 0px 3px 7px -3px"
        },
        "tableHeader": {
          "className": "table-header",
          "display": "flex",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginBottom": "30px"
        },
        "tableTitle": {
          "className": "table-title",
          "fontSize": "1.8rem",
          "fontWeight": 600,
          "color": "#0b2848"
        }
      },
      
      "dataTable": {
        "className": "data-table",
        "width": "100%",
        "borderCollapse": "collapse",
        "th": {
          "textAlign": "left",
          "padding": "15px",
          "fontWeight": 600,
          "color": "#0b2848",
          "borderBottom": "2px solid #eaebef"
        },
        "td": {
          "padding": "15px",
          "borderBottom": "1px solid #eaebef",
          "color": "#506276"
        },
        "tr": {
          "hover": {
            "background": "#dc354533"
          }
        }
      },
      
      "badge": {
        "className": "badge",
        "base": {
          "padding": "5px 12px",
          "borderRadius": "4px",
          "fontSize": "14px",
          "fontWeight": 500
        },
        "success": {
          "className": "badge-success",
          "background": "#25d36633",
          "color": "#25d366"
        },
        "warning": {
          "className": "badge-warning",
          "background": "#ffc81533",
          "color": "#ff7903"
        }
      },
      
      "primaryButton": {
        "className": "primary-button",
        "properties": {
          "textDecoration": "none",
          "color": "#fff",
          "background": "#dc3545",
          "padding": "10px 20px",
          "borderRight": "7px solid #be1929",
          "fontWeight": 300,
          "display": "inline-block",
          "transition": "1s"
        },
        "hover": {
          "background": "#be1929",
          "borderRight": "6px solid #dc3545",
          "color": "#fff"
        }
      },
      
      "quickActions": {
        "className": "quick-actions",
        "properties": {
          "background": "#dc354533",
          "padding": "30px",
          "borderRadius": "5px",
          "marginTop": "60px"
        },
        "title": {
          "className": "quick-actions-title",
          "fontSize": "1.5rem",
          "fontWeight": 600,
          "color": "#77121b",
          "marginBottom": "30px"
        },
        "grid": {
          "className": "actions-grid",
          "display": "grid",
          "gridTemplateColumns": "repeat(auto-fit, minmax(200px, 1fr))",
          "gap": "20px"
        },
        "card": {
          "className": "action-card",
          "properties": {
            "background": "#ffffff",
            "padding": "20px",
            "borderRadius": "5px",
            "textDecoration": "none",
            "color": "#0b2848",
            "transition": "0.5s",
            "borderRight": "1px solid #0b2848"
          },
          "hover": {
            "color": "#011e94"
          },
          "icon": {
            "className": "action-card-icon",
            "width": "40px",
            "height": "40px",
            "marginBottom": "10px"
          },
          "h6": {
            "fontSize": "18px",
            "fontWeight": 600,
            "margin": 0
          }
        }
      }
    },
    
    "effects": {
      "shadows": {
        "header": "#0b28487d 0px 10px 25px -10px",
        "card": "rgba(50, 50, 93, 0.25) 0px 6px 12px -2px, rgba(0, 0, 0, 0.3) 0px 3px 7px -3px",
        "cardHover": "rgba(0, 0, 0, 0.35) 0px 5px 15px"
      },
      "transitions": {
        "default": "0.3s",
        "smooth": "0.5s",
        "slow": "1s",
        "properties": ["background-color", "color", "box-shadow"]
      },
      "gradients": {
        "chartPlaceholder": "linear-gradient(-90deg, #dc354662, #ff790348)",
        "statIcon": "linear-gradient(#011e94, #011e94d4, #011e94b3, #011e9433)",
        "userAvatar": "linear-gradient(#011e94, #011e94d4)"
      }
    },
    
    "responsiveDesign": {
      "breakpoints": {
        "tablet": "max-width: 991px",
        "mobile": "max-width: 576px"
      },
      "adaptations": {
        "tablet": {
          "sectionTitle": {
            "h6": {
              "writingMode": "horizontal-tb",
              "transform": "none",
              "position": "relative",
              "left": 0,
              "fontSize": "15px"
            },
            "accentBar": {
              "width": "4px",
              "height": "100%",
              "left": "-15px"
            }
          },
          "dataSection": {
            "paddingLeft": "15px"
          },
          "mainTitle": {
            "h1": {
              "fontSize": "calc(1.5rem + 1vw)"
            }
          },
          "statsGrid": {
            "gridTemplateColumns": "1fr",
            "gap": "20px"
          }
        },
        "mobile": {
          "navLinks": {
            "display": "none"
          },
          "dashboardContainer": {
            "padding": "40px 15px"
          },
          "chartPlaceholder": {
            "height": "250px"
          }
        }
      }
    },
    
    "interactionPatterns": {
      "hover": {
        "links": {
          "color": "#dc3545",
          "transition": "0.3s"
        },
        "cards": {
          "boxShadow": "rgba(0, 0, 0, 0.35) 0px 5px 15px",
          "transition": "0.5s"
        },
        "buttons": {
          "background": "#be1929",
          "borderRight": "6px solid #dc3545",
          "transition": "1s"
        },
        "actionCards": {
          "color": "#011e94",
          "transition": "0.5s"
        },
        "tableRows": {
          "background": "#dc354533"
        },
        "chartOptions": {
          "background": "#315984",
          "color": "#fff",
          "transition": "1s"
        }
      },
      "active": {
        "chartOption": {
          "className": "active",
          "background": "#315984",
          "color": "#fff"
        }
      }
    },
    
    "iconography": {
      "library": "Font Awesome 6.4.0",
      "cdn": "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css",
      "sizes": {
        "small": "14px-16px",
        "medium": "20px-24px",
        "large": "26px-48px"
      },
      "colors": {
        "default": "#0b2848",
        "white": "#fff",
        "accent": "#011e94"
      },
      "usage": {
        "navigation": "Chart line, video, users, dollar sign icons",
        "cards": "Eye, users, heart, dollar sign icons",
        "actions": "Video, chart bar, bullhorn, cog icons",
        "indicators": "Arrow up for positive changes"
      }
    },
    
    "componentStructure": {
      "header": {
        "structure": "dashboard-header > header-container > (logo-section, nav, user-section)",
        "requiredElements": ["Logo", "Navigation links", "User avatar"]
      },
      "dashboardContainer": {
        "structure": "dashboard-container > (section-title, main-title, stats-grid, chart-section, data-section, quick-actions)",
        "maxWidth": "1200px",
        "padding": "60px 15px"
      },
      "statCard": {
        "structure": "stat-card > (stat-card-header > stat-card-icon, stat-card-value, stat-card-label, stat-card-change)",
        "requiredElements": ["Icon", "Value", "Label", "Change indicator"]
      },
      "chartSection": {
        "structure": "chart-section > (chart-header > chart-title + chart-options, chart-placeholder)",
        "requiredElements": ["Title", "Time period options", "Chart container"]
      },
      "dataTable": {
        "structure": "data-table-card > (table-header > table-title + primary-button, data-table)",
        "requiredElements": ["Title", "Action button", "Table with headers"]
      },
      "quickActions": {
        "structure": "quick-actions > (quick-actions-title, actions-grid > action-card)",
        "requiredElements": ["Title", "Grid of action cards"]
      }
    },
    
    "usageGuidelines": {
      "creatingNewFeatures": {
        "step1": "Use the exact color palette values specified - never use approximations",
        "step2": "Follow the spacing scale consistently - use the exact pixel values",
        "step3": "Apply component styles using the exact class names and properties",
        "step4": "Maintain responsive breakpoints at 991px (tablet) and 576px (mobile)",
