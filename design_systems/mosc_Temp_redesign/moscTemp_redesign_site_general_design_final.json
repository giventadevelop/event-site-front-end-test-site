{
  "designSystem": {
    "name": "MOSC Temp Redesign Creator Analytics Design System",
    "version": "1.0.0",
    "scope": "Exact component styling + high-level design guidance for creator analytics features",
    "description": "Comprehensive implementation and direction guide derived from `moscTemp_redesign_site_general_design.json` and `creator-analytics.html`. Intended to be the primary AI reference for building new dashboard and analytics features in this app.",
    "sourceOfTruth": {
      "primaryDesignGuide": "design_systems/mosc_Temp_redesign/moscTemp_redesign_site_general_design.json",
      "exactReferenceImplementation": "design_systems/mosc_Temp_redesign/creator-analytics.html",
      "appliesTo": [
        "analytics dashboards",
        "creator performance pages",
        "tables, KPI cards, and chart panels",
        "new card-based feature screens"
      ]
    },
    "designIntent": {
      "northStar": "A premium analytics experience with atmospheric depth, high readability, and confident, conversion-friendly hierarchy.",
      "personality": [
        "Cinematic",
        "Data-centric",
        "Polished",
        "Modern-glass",
        "Confident"
      ],
      "experienceGoals": [
        "Immediate visual clarity for key metrics",
        "Fast scanability through structured card clusters",
        "Consistent semantic colors for quick interpretation",
        "Balanced motion and restraint for professional feel"
      ]
    },
    "highLevelGuidelines": {
      "structure": [
        "Use a top utility header, left navigation rail, and right content canvas.",
        "Group content into three levels: KPI strip, analytics panels, and detailed table/report blocks.",
        "Favor card-based composition over long uninterrupted text sections."
      ],
      "spacing": [
        "Keep dense dashboard rhythm: 0.8rem to 1.2rem gap between major modules.",
        "Use tighter internal spacing in data cards (about 1rem) and slightly larger spacing in section headers.",
        "Maintain container breathing room with shell padding and max-width constraints."
      ],
      "typography": [
        "Use Plus Jakarta Sans/DM Sans/Poppins stack for UI and data-heavy screens.",
        "Use medium-to-bold weights for hierarchy (500-700) and high letter-spacing for uppercase labels.",
        "Apply gradient-accent text only for focal words, not entire paragraphs."
      ],
      "colorAndStyle": [
        "Base environment must remain dark atmospheric with layered radial accents.",
        "Primary surface language is purple frosted glass with subtle border and glow.",
        "Semantic metrics must preserve green(up)/rose(down)/blue(neutral)/orange(attention) mapping."
      ],
      "interaction": [
        "Use subtle translate/scale hover states, never aggressive animation.",
        "Hover affordances should indicate depth and interactivity without distracting from data.",
        "Provide responsive simplification as viewport shrinks."
      ]
    },
    "designTokens": {
      "colors": {
        "heroNightPrimary": "#1a0a2e",
        "heroNightSecondary": "#2d1b4e",
        "heroNightTertiary": "#1e1b4b",
        "heroNightDeep": "#0f172a",
        "softGreen": "#f0fdf4",
        "headingStrong": "#1e1b4b",
        "bodyPrimary": "#312e81",
        "bodySecondary": "#475569",
        "onDarkPrimary": "#f8fafc",
        "onDarkSecondary": "rgba(248, 250, 252, 0.92)",
        "semantic": {
          "blue": "#3b82f6",
          "green": "#22c55e",
          "purple": "#a855f7",
          "orange": "#f97316",
          "gold": "#f59e0b",
          "cyan": "#22d3ee",
          "magenta": "#e879f9"
        },
        "status": {
          "positiveText": "#166534",
          "negativeText": "#9f1239",
          "mediumText": "#9a3412",
          "lowText": "#1d4ed8"
        }
      },
      "glass": {
        "purpleGlassGradient": "linear-gradient(145deg, rgba(196, 181, 253, 0.96) 0%, rgba(167, 139, 250, 0.94) 48%, rgba(183, 148, 252, 0.95) 100%)",
        "purpleGlassBorder": "rgba(237, 233, 254, 0.82)",
        "purpleGlassShadow": "0 4px 14px rgba(76, 29, 149, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.75)",
        "purpleGlassShadowHover": "0 10px 28px rgba(76, 29, 149, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.9)",
        "panelBlur": "blur(18px)"
      },
      "typography": {
        "fontFamilyUi": "\"Plus Jakarta Sans\", \"DM Sans\", \"Poppins\", \"Segoe UI\", Arial, sans-serif",
        "weights": {
          "regular": 400,
          "medium": 500,
          "semibold": 600,
          "bold": 700
        },
        "sizes": {
          "heroTitle": "clamp(1.5rem, 3vw, 2.15rem)",
          "sectionTitle": "1rem",
          "kpiValue": "1.6rem",
          "body": "0.96rem",
          "meta": "0.8rem",
          "caption": "0.76rem"
        },
        "tracking": {
          "label": "0.08em",
          "tableHeader": "0.06em",
          "brand": "0.02em"
        }
      },
      "radius": {
        "card": "1rem",
        "innerPanel": "0.85rem",
        "chip": "999px",
        "menuItem": "0.65rem"
      },
      "spacing": {
        "shellPadding": "1.25rem 1rem 2rem",
        "topbarPadding": "0.9rem 1rem",
        "cardPadding": "1rem",
        "kpiGap": "0.8rem",
        "layoutGap": "1rem",
        "tableCellPadding": "0.72rem 0.78rem"
      },
      "motion": {
        "standardTransition": "0.25s to 0.3s ease",
        "hoverLiftSmall": "translateY(-1px)",
        "hoverLiftCard": "translateY(-4px)"
      }
    },
    "globalLayoutSpec": {
      "body": {
        "margin": "0",
        "minHeight": "100vh",
        "overflowX": "hidden",
        "backgroundLayers": [
          "radial gradient at 12% 18% using cyan tint",
          "radial gradient at 85% 10% using magenta tint",
          "linear gradient (140deg) from heroNightPrimary to heroNightDeep"
        ]
      },
      "dashboardShell": {
        "maxWidth": "1280px",
        "margin": "0 auto",
        "padding": "1.25rem 1rem 2rem"
      },
      "layoutGrid": {
        "desktop": "240px sidebar + flexible main",
        "tabletDown": "single column stack",
        "gap": "1rem"
      }
    },
    "componentSpecs": {
      "topbar": {
        "selector": ".topbar",
        "structure": [
          "brand cluster left",
          "action chips right"
        ],
        "styles": {
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "space-between",
          "gap": "1rem",
          "padding": "0.9rem 1rem",
          "border": "1px solid rgba(255,255,255,0.14)",
          "background": "rgba(26, 10, 46, 0.58)",
          "backdropFilter": "blur(12px)",
          "borderRadius": "1rem",
          "marginBottom": "1.2rem"
        }
      },
      "siteHeaderScrollBehavior": {
        "selector": ".header-glass",
        "appliesToRoutes": [
          "/",
          "/team",
          "/sponsors"
        ],
        "topState": {
          "background": "transparent",
          "backdropFilter": "none",
          "borderBottom": "none",
          "boxShadow": "none"
        },
        "scrolledState": {
          "triggerClass": ".header-glass--scrolled",
          "background": "linear-gradient(180deg, rgba(26, 10, 46, 0.95) 0%, rgba(26, 10, 46, 0.84) 72%, rgba(26, 10, 46, 0.62) 100%)",
          "backdropFilter": "blur(18px) saturate(160%)",
          "borderBottom": "1px solid rgba(255, 255, 255, 0.1)",
          "boxShadow": "0 4px 24px rgba(0, 0, 0, 0.35), 0 1px 0 rgba(255, 255, 255, 0.06) inset",
          "afterGradientStrip": "linear-gradient(180deg, rgba(26, 10, 46, 0.45) 0%, transparent 100%)"
        }
      },
      "brandCluster": {
        "selector": ".brand",
        "elements": {
          "dot": {
            "selector": ".brand-dot",
            "size": "0.7rem x 0.7rem",
            "shape": "circle",
            "fill": "linear-gradient(135deg, cyan -> magenta)",
            "halo": "0 0 0 4px rgba(196,181,253,0.2)"
          },
          "title": {
            "selector": ".brand h1",
            "fontSize": "1rem",
            "fontWeight": 700,
            "letterSpacing": "0.02em"
          },
          "subtitle": {
            "selector": ".brand p",
            "fontSize": "0.8rem",
            "color": "onDarkSecondary"
          }
        }
      },
      "topActionChip": {
        "selector": ".chip-btn",
        "styles": {
          "border": "1px solid rgba(255,255,255,0.25)",
          "background": "rgba(109,40,217,0.45)",
          "color": "#fff",
          "borderRadius": "999px",
          "padding": "0.48rem 0.85rem",
          "fontSize": "0.78rem",
          "fontWeight": 600
        },
        "hover": {
          "transform": "translateY(-1px)",
          "background": "rgba(109,40,217,0.8)",
          "shadow": "0 8px 16px rgba(109,40,217,0.35)"
        }
      },
      "sidebar": {
        "selector": ".sidebar",
        "styles": {
          "surface": "purple glass",
          "padding": "1rem",
          "height": "fit-content",
          "position": "sticky",
          "top": "1rem"
        },
        "eyebrowPill": {
          "selector": ".rail-eyebrow",
          "styles": {
            "display": "inline-flex",
            "gap": "0.45rem",
            "background": "rgba(255,255,255,0.88)",
            "textColor": "#0f172a",
            "borderRadius": "999px",
            "padding": "0.35rem 0.7rem",
            "fontSize": "0.72rem",
            "fontWeight": 700,
            "textTransform": "uppercase",
            "letterSpacing": "0.08em"
          },
          "mark": {
            "selector": ".rail-mark",
            "size": "1rem x 0.42rem",
            "radius": "0.25rem",
            "color": "#facc15"
          }
        },
        "menuLink": {
          "selector": ".menu a",
          "styles": {
            "fontSize": "0.9rem",
            "fontWeight": 600,
            "color": "bodyPrimary",
            "background": "rgba(255,255,255,0.28)",
            "padding": "0.62rem 0.7rem",
            "borderRadius": "0.65rem"
          },
          "active": {
            "background": "rgba(99,102,241,0.32)",
            "color": "headingStrong"
          },
          "hover": {
            "background": "rgba(255,255,255,0.5)",
            "transform": "translateX(2px)"
          }
        }
      },
      "mainHeader": {
        "selector": ".main-header",
        "styles": {
          "padding": "1rem 1rem 0.2rem"
        },
        "title": {
          "selector": ".main-header h2",
          "fontSize": "clamp(1.5rem, 3vw, 2.15rem)",
          "fontWeight": 500,
          "color": "onDarkPrimary",
          "lineHeight": 1.15
        },
        "accentWord": {
          "selector": ".main-header .accent",
          "gradient": "linear-gradient(90deg, blue -> purple)",
          "textFill": "transparent",
          "fontWeight": 600
        },
        "description": {
          "selector": ".main-header p",
          "fontSize": "0.96rem",
          "color": "onDarkSecondary"
        }
      },
      "glassCardBase": {
        "selectors": [
          ".glass-card",
          ".sidebar"
        ],
        "styles": {
          "background": "purpleGlassGradient",
          "border": "1px solid purpleGlassBorder",
          "shadow": "purpleGlassShadow",
          "backdropFilter": "blur(18px)",
          "borderRadius": "1rem"
        }
      },
      "kpiCard": {
        "selector": ".kpi-card",
        "layout": "4-up desktop, 2-up tablet, 1-up mobile",
        "styles": {
          "padding": "1rem"
        },
        "hover": {
          "transform": "translateY(-4px)",
          "shadow": "purpleGlassShadowHover"
        },
        "subparts": {
          "label": {
            "selector": ".kpi-label",
            "fontSize": "0.78rem",
            "fontWeight": 700,
            "letterSpacing": "0.08em",
            "textTransform": "uppercase",
            "color": "bodySecondary"
          },
          "value": {
            "selector": ".kpi-value",
            "fontSize": "1.6rem",
            "fontWeight": 700,
            "color": "headingStrong",
            "lineHeight": 1
          },
          "meta": {
            "selector": ".kpi-meta",
            "fontSize": "0.8rem",
            "fontWeight": 600
          },
          "positiveState": {
            "selector": ".up",
            "color": "#166534"
          },
          "negativeState": {
            "selector": ".down",
            "color": "#9f1239"
          }
        }
      },
      "analyticsPanel": {
        "selector": ".panel",
        "layout": "left wide trend panel + right audience panel",
        "styles": {
          "padding": "1rem",
          "minHeight": "320px"
        },
        "title": {
          "selector": ".panel h3",
          "fontSize": "1rem",
          "fontWeight": 700,
          "color": "headingStrong"
        },
        "subtitle": {
          "selector": ".panel-sub",
          "fontSize": "0.82rem",
          "color": "bodySecondary"
        },
        "chartShell": {
          "selector": ".chart-shell",
          "styles": {
            "height": "230px",
            "radius": "0.85rem",
            "border": "1px solid rgba(255,255,255,0.55)",
            "background": "soft white vertical gradient + repeating vertical grid line",
            "overflow": "hidden",
            "position": "relative"
          }
        },
        "legend": {
          "selector": ".legend",
          "fontSize": "0.78rem",
          "fontWeight": 600,
          "color": "bodyPrimary",
          "dotSize": "0.62rem"
        }
      },
      "tablePanel": {
        "selector": ".table-panel",
        "styles": {
          "padding": "1rem"
        },
        "tableShell": {
          "selector": ".table-shell",
          "styles": {
            "overflow": "auto",
            "border": "1px solid rgba(255,255,255,0.5)",
            "borderRadius": "0.85rem",
            "background": "rgba(255,255,255,0.33)"
          }
        },
        "table": {
          "selector": "table",
          "minWidth": "520px",
          "cellPadding": "0.72rem 0.78rem",
          "cellBorderBottom": "1px solid rgba(255,255,255,0.45)"
        },
        "headerCells": {
          "selector": "th",
          "fontSize": "0.76rem",
          "fontWeight": 700,
          "letterSpacing": "0.06em",
          "textTransform": "uppercase",
          "color": "headingStrong",
          "background": "rgba(255,255,255,0.35)"
        },
        "bodyCells": {
          "selector": "td",
          "fontSize": "0.84rem",
          "color": "bodyPrimary"
        }
      },
      "priorityBadge": {
        "selector": ".badge",
        "base": {
          "display": "inline-flex",
          "radius": "999px",
          "padding": "0.22rem 0.58rem",
          "fontSize": "0.74rem",
          "fontWeight": 700
        },
        "variants": {
          "high": {
            "selector": ".badge.high",
            "background": "rgba(34,197,94,0.2)",
            "color": "#166534"
          },
          "medium": {
            "selector": ".badge.medium",
            "background": "rgba(249,115,22,0.2)",
            "color": "#9a3412"
          },
          "low": {
            "selector": ".badge.low",
            "background": "rgba(59,130,246,0.2)",
            "color": "#1d4ed8"
          }
        }
      }
    },
    "responsiveSpec": {
      "breakpoint1120": {
        "condition": "(max-width: 1120px)",
        "changes": [
          "layout switches to single column",
          "sidebar becomes non-sticky/static",
          "kpi grid becomes 2 columns",
          "analytics panel grid becomes 1 column"
        ]
      },
      "breakpoint680": {
        "condition": "(max-width: 680px)",
        "changes": [
          "kpi grid becomes 1 column",
          "topbar stacks vertically",
          "top actions align left and occupy full width"
        ]
      }
    },
    "implementationPatterns": {
      "requiredPatterns": [
        "Use atmospheric multi-layer background on dashboard pages.",
        "Use purple glass cards for all major content modules.",
        "Use uppercase micro-labels for KPI category metadata.",
        "Use semantic text colors for up/down performance deltas.",
        "Use one large analytics grid + one table/report section below.",
        "Use compact control chips in top-right utility area."
      ],
      "chartGuidelines": [
        "Use rounded chart container with soft grid texture.",
        "Use gradient line strokes for key series.",
        "Keep legends concise and color-dot matched.",
        "Avoid overcrowded axis labels in compact dashboard mode."
      ],
      "tableGuidelines": [
        "Always wrap tables in overflow container with rounded shell.",
        "Use uppercase table headers with increased tracking.",
        "Keep row text compact and numeric columns quickly scannable.",
        "Use priority/status badges for rapid visual triage."
      ]
    },
    "aiBuildRules": {
      "whenCreatingNewFeatures": [
        "Start from the existing token palette and do not introduce unrelated base colors.",
        "Reuse `glass-card` style language for all new cards unless explicitly overridden.",
        "Preserve hierarchy order: utility header > KPIs > analysis > detailed list.",
        "Favor semantic icon/color coding over decorative color usage.",
        "Ensure hover interactions are subtle and consistent (`translateY`, soft shadow).",
        "Always include mobile fallbacks and test stack behavior at <=1120 and <=680 widths."
      ],
      "doNot": [
        "Do not switch to flat opaque white cards on this dashboard style.",
        "Do not use heavy motion or long animation chains for data interfaces.",
        "Do not mix conflicting font families or random gradients.",
        "Do not remove contrast between dark environment and glass surfaces.",
        "Do not use low-contrast body copy on glass surfaces."
      ],
      "qualityChecklist": [
        "Dark atmospheric shell present",
        "Purple glass token consistency across cards",
        "KPI cards readable in all breakpoints",
        "Panel and table typography hierarchy intact",
        "Status badges and semantic states visible",
        "No horizontal overflow on main layout (except intentional table scroll shell)"
      ]
    },
    "engineeringNotes": {
      "preferredApproach": "Token-first CSS variables with component-level classes",
      "extensibility": [
        "Add new card modules by extending `.glass-card` and local sub-classes.",
        "Add new chart panels by reusing `.panel`, `.chart-shell`, and `.legend` structure.",
        "Add new summary strips by reusing `.kpi-card` semantics."
      ],
      "accessibilityBaseline": [
        "Preserve text contrast on glass surfaces.",
        "Keep interactive elements keyboard-focusable and visibly distinct.",
        "Retain legible minimum sizes for metadata and labels."
      ]
    }
  }
}
