{
  "designSystem": {
    "name": "Syro-Malabar Church Design System",
    "version": "1.0.0",
    "description": "Comprehensive design guidelines for Syro-Malabar Church website, capturing high-level design patterns, colors, typography, spacing, and component styles to enable AI-assisted replication of the visual design.",
    
    "designPhilosophy": {
      "overview": "A modern, dignified design system that balances religious solemnity with contemporary web aesthetics. The design emphasizes hierarchy, visual storytelling through imagery, and bilingual accessibility.",
      "corePrinciples": [
        "Visual hierarchy through typography and spacing",
        "Image-driven content presentation",
        "Bilingual design support (English/Malayalam)",
        "Elegant use of gradients and shadows for depth",
        "Geometric accents and decorative elements",
        "Responsive-first approach",
        "Accessibility and readability",
        "Smooth transitions and subtle animations"
      ],
      "designStyle": "Contemporary religious website with modern web design elements, featuring layered compositions, gradient accents, and geometric patterns. The aesthetic balances traditional reverence with digital innovation."
    },
    
    "colorPalette": {
      "primary": {
        "red": {
          "main": "#dc3545",
          "description": "Primary brand color - used for CTAs, accents, and highlights",
          "darker": "#be1929",
          "hover": "#990b3f",
          "light": "#dc354533",
          "usage": ["Primary buttons", "Section title accents", "Hover states", "Important text highlights"]
        },
        "blue": {
          "main": "#0b2848",
          "description": "Primary dark blue - main text and headers",
          "secondary": "#011e94",
          "light": "#798daf",
          "dark": "#16253c",
          "usage": ["Main headings", "Navigation", "Body text", "Footer backgrounds", "Form borders"]
        }
      },
      "secondary": {
        "orange": {
          "main": "#ff7903",
          "description": "Accent orange - used for highlights and interactive elements",
          "usage": ["Liturgy highlights", "Icon accents", "Hover states", "Gradient elements"]
        },
        "purple": {
          "main": "#6e1b48",
          "description": "Deep purple - used for special sections and backgrounds",
          "usage": ["Notification bars", "Special section backgrounds", "Toggles"]
        },
        "maroon": {
          "main": "#77121b",
          "description": "Maroon accent - used for certain card styles",
          "usage": ["Quick link cards", "Text highlights"]
        }
      },
      "neutrals": {
        "white": "#ffffff",
        "lightGray": "#eaebef",
        "backgroundGray": "#f5f6f7",
        "textGray": "#818181",
        "mediumGray": "#7b869a",
        "darkGray": "#506276"
      },
      "backgrounds": {
        "gradientOverlay": "linear-gradient(-90deg, #dc354662, #ff790348)",
        "heroGradient": "linear-gradient(180deg, #ff7903, #dc3545, #dc354599, #011e9400)",
        "cardinalGradient": "linear-gradient(#db33709e, #04239687)",
        "backgroundPattern": "url(../images/background/bg-rectangle.png)",
        "usage": "Subtle gradient overlays used for depth and visual interest in sections"
      },
      "semantic": {
        "success": "#25d366",
        "info": "#1ea1f2",
        "warning": "#ffc815",
        "error": "#dc3545",
        "danger": "#dc3545"
      }
    },
    
    "typography": {
      "fontFamilies": {
        "primary": {
          "name": "Poppins",
          "weights": [100, 200, 300, 400, 500, 600, 700, 800],
          "usage": "General body text and UI elements",
          "fallback": "Arial, Helvetica, sans-serif"
        },
        "display": {
          "name": "Playfair Display",
          "weights": [400, 600, 700, 800],
          "usage": "Large headings and display text",
          "fallback": "serif"
        },
        "malayalam": {
          "name": "Anek Malayalam",
          "weights": [100, 200, 300, 400, 500, 600, 700, 800],
          "usage": "Malayalam language content",
          "fallback": "sans-serif"
        },
        "bodyEnglish": {
          "name": "Arial",
          "fallback": "Helvetica, sans-serif",
          "usage": "English body text and content"
        }
      },
      "scale": {
        "hero": {
          "size": "6.5rem",
          "weight": 800,
          "lineHeight": "1.2",
          "usage": "Main hero headings"
        },
        "h1": {
          "size": "2.8rem",
          "weight": 700,
          "color": "#0b2848",
          "usage": "Primary section headings"
        },
        "h2": {
          "size": "2.2rem",
          "weight": 700,
          "color": "#0b2848",
          "usage": "Secondary section headings"
        },
        "h3": {
          "size": "1.8rem",
          "weight": 600,
          "usage": "Subsection headings"
        },
        "h4": {
          "size": "1.5rem",
          "weight": 500,
          "usage": "Card titles and smaller headings"
        },
        "h5": {
          "size": "1.2rem",
          "weight": 500,
          "usage": "Small headings"
        },
        "h6": {
          "size": "1rem",
          "weight": 400,
          "usage": "Labels and small text"
        },
        "body": {
          "size": "20px",
          "weight": 400,
          "lineHeight": "35px",
          "usage": "Main body text"
        },
        "small": {
          "size": "16px",
          "weight": 300,
          "usage": "Secondary text and captions"
        },
        "tiny": {
          "size": "14px",
          "weight": 300,
          "usage": "Labels and metadata"
        }
      },
      "special": {
        "sectionTitle": {
          "writingMode": "vertical-lr",
          "transform": "rotate(180deg)",
          "letterSpacing": "5px",
          "fontSize": "24px",
          "fontWeight": 300,
          "color": "#798daf",
          "description": "Vertical section labels positioned on the left side of sections"
        },
        "backgroundText": {
          "fontSize": "250px",
          "fontWeight": 900,
          "opacity": 0.07,
          "textTransform": "uppercase",
          "description": "Large watermarked background text for visual depth"
        }
      }
    },
    
    "spacing": {
      "scale": {
        "xs": "5px",
        "sm": "10px",
        "md": "20px",
        "lg": "30px",
        "xl": "40px",
        "xxl": "60px",
        "xxxl": "80px"
      },
      "sectionPadding": {
        "vertical": "60px",
        "horizontal": "80px",
        "mobileVertical": "40px",
        "mobileHorizontal": "15px"
      },
      "containerPadding": {
        "desktop": "0 15px",
        "mobile": "0 10px"
      },
      "gridGutter": {
        "desktop": "30px",
        "mobile": "15px"
      },
      "componentSpacing": {
        "card": {
          "padding": "40px",
          "margin": "15px",
          "gap": "20px"
        },
        "button": {
          "padding": "10px 20px",
          "border": "7px solid accent color"
        },
        "form": {
          "inputPadding": "10px 20px",
          "inputMargin": "0 0 10px 0",
          "labelSpacing": "5px"
        }
      }
    },
    
    "layout": {
      "container": {
        "maxWidth": "1200px",
        "padding": "0 15px",
        "breakpoints": {
          "xs": "576px",
          "sm": "768px",
          "md": "992px",
          "lg": "1200px",
          "xl": "1400px"
        }
      },
      "gridSystem": "Bootstrap 5 grid (12 columns)",
      "sections": {
        "paddingTop": "60px",
        "paddingBottom": "60px",
        "alternating": false
      },
      "sidebar": {
        "width": "310px",
        "position": "fixed right",
        "background": "#6e1b48"
      }
    },
    
    "components": {
      "buttons": {
        "primary": {
          "background": "#dc3545",
          "color": "#ffffff",
          "padding": "10px 20px",
          "border": "none",
          "borderRight": "7px solid #be1929",
          "fontWeight": 300,
          "transition": "1s",
          "hover": {
            "background": "#be1929",
            "borderRight": "6px solid #dc3545"
          },
          "description": "Main call-to-action button with distinctive right border accent"
        },
        "secondary": {
          "background": "transparent",
          "color": "#0b2848",
          "border": "2px solid #315984",
          "padding": "0px 10px",
          "hover": {
            "background": "#315984",
            "color": "#ffffff"
          }
        },
        "text": {
          "color": "#0b2848",
          "textDecoration": "none",
          "fontWeight": 300,
          "hover": {
            "color": "#dc3545"
          }
        }
      },
      
      "cards": {
        "default": {
          "background": "#ffffff",
          "padding": "10px",
          "borderRadius": "5px",
          "boxShadow": "rgba(50, 50, 93, 0.25) 0px 6px 12px -2px, rgba(0, 0, 0, 0.3) 0px 3px 7px -3px",
          "transition": "0.5s",
          "hover": {
            "boxShadow": "rgba(0, 0, 0, 0.35) 0px 5px 15px"
          }
        },
        "content": {
          "background": "#ffffff",
          "padding": "40px",
          "boxShadow": "rgba(0, 0, 0, 0.25) 0px 3px 12px",
          "border": "none"
        },
        "image": {
          "borderRadius": "5px",
          "overflow": "hidden",
          "objectFit": "cover",
          "aspectRatio": "4/3"
        }
      },
      
      "navigation": {
        "header": {
          "background": "#ffffff",
          "padding": "0.5rem 0",
          "sticky": {
            "background": "#ffffff",
            "boxShadow": "#0b28487d 0px 10px 25px -10px",
            "padding": "0.5rem 0"
          }
        },
        "links": {
          "color": "#0b2848",
          "fontWeight": 500,
          "transition": "0.3s",
          "hover": {
            "color": "#dc3545"
          },
          "active": {
            "background": "#dc3545",
            "color": "#ffffff"
          }
        },
        "dropdown": {
          "borderRadius": 0,
          "boxShadow": "rgba(0, 0, 0, 0.19) 0px 10px 20px, rgba(0, 0, 0, 0.23) 0px 6px 6px",
          "itemHover": {
            "color": "#dc3545"
          }
        }
      },
      
      "forms": {
        "input": {
          "background": "transparent",
          "border": "none",
          "borderBottom": "1px solid #ffffff",
          "borderRadius": 0,
          "color": "#ffffff",
          "fontSize": "18px",
          "padding": "10px 0",
          "focus": {
            "background": "transparent",
            "borderBottom": "1px solid #ffffff",
            "boxShadow": "none",
            "color": "#ffffff"
          }
        },
        "label": {
          "color": "#ffffff",
          "fontWeight": 300,
          "paddingLeft": 0
        },
        "textarea": {
          "height": "100px",
          "resize": "none"
        },
        "search": {
          "border": "2px solid #0b2848",
          "background": "#ffffff",
          "icon": {
            "background": "#ffffff",
            "border": "2px solid #011e94",
            "color": "#011e94"
          }
        }
      },
      
      "modals": {
        "overlay": "rgba(101, 108, 133, 0.8)",
        "content": {
          "background": "#f5f6f7",
          "borderRadius": 0
        },
        "header": {
          "border": "none",
          "padding": "20px"
        }
      },
      
      "breadcrumbs": {
        "container": {
          "background": "linear-gradient(-90deg, #dc354662, #ff790348)",
          "minHeight": "150px",
          "padding": "20px",
          "textTransform": "uppercase"
        },
        "link": {
          "color": "#990b3f",
          "hover": "#dc3545"
        },
        "active": {
          "color": "#dc3545"
        }
      },
      
      "badges": {
        "default": {
          "padding": "8px 12px",
          "borderRadius": "4px",
          "fontSize": "14px",
          "fontWeight": 500
        },
        "date": {
          "background": "#00000069",
          "color": "#ffffff",
          "padding": "8px",
          "fontSize": "14px"
        }
      },
      
      "tabs": {
        "nav": {
          "background": "#d74754",
          "border": "none",
          "padding": "10px"
        },
        "link": {
          "color": "#990b3f",
          "border": "2px solid #315984",
          "background": "transparent",
          "padding": "0px 10px",
          "borderRadius": 0
        },
        "active": {
          "background": "#db3370",
          "color": "#ffffff"
        }
      },
      
      "sliders": {
        "navigation": {
          "color": "#dc3545",
          "size": "30px",
          "hover": "#990b3f"
        },
        "pagination": {
          "bullet": {
            "size": "8px",
            "active": "#dc3545",
            "inactive": "#798daf"
          }
        }
      },
      
      "gallery": {
        "grid": {
          "columns": "4",
          "gap": "10px",
          "aspectRatio": "4/3"
        },
        "overlay": {
          "background": "linear-gradient(rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.2), rgb(0 0 0 / 56%))",
          "position": "absolute",
          "bottom": 0
        },
        "zoomIcon": {
          "size": "40px",
          "background": "#dc3545",
          "color": "#ffffff"
        }
      }
    },
    
    "effects": {
      "shadows": {
        "small": "rgba(60, 64, 67, 0.3) 0px 1px 2px 0px, rgba(60, 64, 67, 0.15) 0px 2px 6px 2px",
        "medium": "rgba(50, 50, 93, 0.25) 0px 6px 12px -2px, rgba(0, 0, 0, 0.3) 0px 3px 7px -3px",
        "large": "rgba(0, 0, 0, 0.19) 0px 10px 20px, rgba(0, 0, 0, 0.23) 0px 6px 6px",
        "image": "#011e946b 15px 20px 35px -10px, #dc354540 0px 5px 50px 5px",
        "header": "#0b28487d 0px 10px 25px -10px"
      },
      "gradients": {
        "hero": "linear-gradient(180deg, #ff7903, #dc3545, #dc354599, #011e9400)",
        "cardinal": "linear-gradient(#db33709e, #04239687)",
        "breadcrumb": "linear-gradient(-90deg, #dc354662, #ff790348)",
        "button": "linear-gradient(#011e94, #011e94d4, #011e94b3, #011e9433)",
        "image": "linear-gradient(#dc3545, #dc354588, #eaebef59)"
      },
      "blur": {
        "small": "1px",
        "medium": "50px",
        "large": "100px",
        "usage": "Applied to decorative background elements for depth"
      },
      "transitions": {
        "default": "0.3s",
        "smooth": "0.5s",
        "slow": "1s",
        "properties": ["background-color", "color", "transform", "box-shadow", "border"]
      },
      "animations": {
        "fadeIn": "fadeIn 0.5s",
        "fadeOut": "fadeOut 0.5s",
        "bounceInLeft": "bounceInLeft 2s",
        "flipInX": "flipInX 4s"
      }
    },
    
    "decorativeElements": {
      "sectionTitleAccent": {
        "type": "vertical bar",
        "width": "7px",
        "height": "120%",
        "color": "#dc3545",
        "position": "absolute left of section title",
        "description": "Red vertical accent bar next to vertical section titles"
      },
      "backgroundPatterns": {
        "rectanglePattern": "bg-rectangle.png",
        "mapPattern": "map_with_points.png",
        "crossPattern": "cross_white.svg",
        "usage": "Subtle background patterns for visual texture",
        "opacity": 0.03,
        "blend": "overlay"
      },
      "geometricShapes": {
        "circles": "Used in gradients and blur effects",
        "rectangles": "Border accents on buttons and cards",
        "usage": "Decorative elements created with CSS pseudo-elements"
      }
    },
    
    "imagery": {
      "imageTreatment": {
        "borders": {
          "width": "10px",
          "color": "#ffffff",
          "style": "solid"
        },
        "shadows": "Multi-layered shadows for depth",
        "objectFit": "cover",
        "lazyLoading": true,
        "placeholder": "Fade-in animation on load"
      },
      "imageCompositions": {
        "stacked": "Images arranged in overlapping layers",
        "grid": "Gallery grids with consistent aspect ratios",
        "hero": "Full-width hero images with text overlay",
        "card": "Images in cards with hover zoom effects"
      },
      "aspectRatios": {
        "hero": "16:9 or full viewport",
        "card": "4:3",
        "thumbnail": "1:1",
        "gallery": "4:3"
      }
    },
    
    "accessibility": {
      "contrast": {
        "textOnLight": "WCAG AA compliant",
        "textOnDark": "WCAG AA compliant",
        "minimum": "4.5:1 for normal text",
        "large": "3:1 for large text"
      },
      "focusStates": {
        "outline": "2px solid accent color",
        "visibility": "Always visible"
      },
      "languageSupport": {
        "bilingual": true,
        "languages": ["English", "Malayalam"],
        "fontSelection": "Automatic based on language attribute",
        "direction": "LTR for both languages"
      },
      "screenReaderSupport": {
        "ariaLabels": "Used throughout",
        "semanticHTML": "Emphasized",
        "skipLinks": "Recommended"
      }
    },
    
    "responsiveDesign": {
      "breakpoints": {
        "mobile": "max-width: 576px",
        "tablet": "min-width: 577px, max-width: 991px",
        "desktop": "min-width: 992px",
        "large": "min-width: 1200px",
        "xlarge": "min-width: 1400px"
      },
      "mobileAdaptations": {
        "typography": "Reduced font sizes (calc(1.5rem + 1vw))",
        "spacing": "Reduced padding and margins",
        "sectionTitles": "Horizontal instead of vertical",
        "navigation": "Offcanvas menu",
        "images": "Full width, simplified compositions"
      },
      "touchTargets": {
        "minimum": "44x44px",
        "recommended": "48x48px"
      }
    },
    
    "interactionPatterns": {
      "hover": {
        "links": "Color change to #dc3545",
        "buttons": "Background darken, border swap",
        "cards": "Shadow increase, slight scale",
        "images": "Scale 1.2 with transition"
      },
      "loading": {
        "indicator": "GIF loader centered",
        "lazyImages": "Fade-in on load",
        "skeleton": "Not implemented"
      },
      "transitions": {
        "default": "Smooth 0.3s - 1s transitions",
        "easing": "ease-in-out"
      }
    },
    
    "iconography": {
      "library": "Font Awesome 6",
      "size": {
        "small": "16px",
        "medium": "24px",
        "large": "40px"
      },
      "color": {
        "default": "#0b2848",
        "accent": "#dc3545",
        "white": "#ffffff"
      },
      "usage": "Navigation, buttons, decorative elements, social media"
    },
    
    "specialSections": {
      "hero": {
        "height": "92vh",
        "slider": true,
        "overlay": "Dark gradient for text readability",
        "pagination": "Vertical dots on right side"
      },
      "about": {
        "layout": "Two-column with images",
        "backgroundText": "Watermarked 'About Us' text",
        "imageComposition": "Stacked images with shadows"
      },
      "cardinal": {
        "background": "Pattern image with gradients",
        "imageStyle": "Black and white + color overlay",
        "accentColors": ["#db3370", "#04239687"]
      },
      "liturgy": {
        "background": "#0b2848",
        "textColor": "#ffffff",
        "accentColor": "#ff7903",
        "layout": "Dark section with image and tabbed content"
      },
      "footer": {
        "background": "#0b2848",
        "contactSection": "#be1929cc",
        "textColor": "#ffffff",
        "layout": "Three-column with contact form"
      }
    },
    
    "implementationNotes": {
      "frameworks": {
        "css": "Bootstrap 5",
        "javascript": "jQuery 3.6.0",
        "sliders": "Swiper.js, Tiny Slider",
        "lightbox": "Glightbox",
        "lazyLoading": "lozad.js",
        "animations": "WOW.js, Animate.css"
      },
      "cssArchitecture": {
        "approach": "Custom CSS with Bootstrap base",
        "organization": "Main style.css + style-inner.css for inner pages",
        "naming": "BEM-like with descriptive classes",
        "important": "Strategic use of !important for overrides"
      },
      "bestPractices": [
        "Always use border-box sizing",
        "Implement lazy loading for images",
        "Use transitions for interactive elements",
        "Maintain consistent spacing scale",
        "Test bilingual content rendering",
        "Ensure proper contrast ratios",
        "Use semantic HTML structure",
        "Implement proper z-index layering"
      ]
    },
    
    "usageGuidelines": {
      "colorApplication": {
        "primaryRed": "Use for primary actions, important highlights, and accents",
        "primaryBlue": "Use for headings, body text, and structural elements",
        "orange": "Use sparingly for special highlights and liturgy elements",
        "gradients": "Apply subtly for depth and visual interest"
      },
      "typographyHierarchy": {
        "mainTitle": "2.8rem, bold, for major sections",
        "sectionTitle": "Vertical text on left, 24px, light weight",
        "bodyText": "20px, regular weight, 35px line height",
        "accentText": "Use red (#dc3545) for emphasis within text"
      },
      "spacingRules": {
        "sections": "60px vertical padding",
        "components": "20px minimum gap between elements",
        "container": "80px left padding on desktop (for section titles)",
        "mobile": "Reduce all spacing by 30-40%"
      },
      "componentComposition": {
        "cards": "White background, subtle shadow, rounded corners",
        "buttons": "Always include right border accent, smooth transitions",
        "forms": "Transparent inputs with bottom borders on dark backgrounds",
        "images": "10px white borders, layered shadows, cover object-fit"
      }
    }
  }
}
