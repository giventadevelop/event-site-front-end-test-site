# Optional fallback when mosc-temp\.env.local is not present.
# Primary source for /REMOTE is mosc-temp\.env.local with:
#   RDS_ENDPOINT, DB_NAME, DB_USERNAME, DB_PASSWORD
#
# Copy to database_target.local.env only if you do not use .env.local.
# NEVER commit database_target.local.env — it contains production credentials.

DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_NAME=event_site_manager_db
DB_USER=postgres
DB_PASSWORD=replace_me
DB_SSLMODE=require
